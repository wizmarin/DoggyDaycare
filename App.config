<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<configSections>
		<section name="users"
				 type="System.Configuration.NameValueSectionHandler" />
		<section name="usersCreds"
				 type="System.Configuration.NameValueSectionHandler" />
	</configSections>
	
	<appSettings>
		<!-- Database Credintials. -->
		<add key="Home_Server_Encrypted_Credentials"
			 value="" />
		<add key="MTU_Server_Encrypted_Credentials"
			 value="" />
		<add key="RsaPrivateKeyPath"
			 value="OneDrive - Munster Technological University\SEP\Credentials_Private_Key.xml" />
	</appSettings>
	
	<users>
		<add key="admin"
			 value="admin"/>
		<add key="recpt"
			 value="recpt"/>
	</users>
	
	<usersCreds>
		<add key="admin"
			 value="admin"/>
		<add key="recpt"
			 value="recpt"/>
	</usersCreds>
</configuration>